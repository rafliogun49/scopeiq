# Production Caddyfile — see PRD §23.6
# C-PR8 fills in the real domain / IP.

# ── Option A: with a domain ──────────────────────────────────────────────────
# scopeiq.yourdomain.com {
#     reverse_proxy frontend:80
# }
#
# api.scopeiq.yourdomain.com {
#     reverse_proxy fastapi:8000
#     # Long timeouts for SSE streams
#     @sse path /api/v1/runs/*/stream
#     handle @sse {
#         reverse_proxy fastapi:8000 {
#             flush_interval -1
#         }
#     }
# }

# ── Option B: IP-only (self-signed cert) ─────────────────────────────────────
:443 {
    tls internal

    handle /api/* {
        reverse_proxy fastapi:8000 {
            flush_interval -1
        }
    }

    handle {
        reverse_proxy frontend:80
    }
}

:80 {
    redir https://{host}{uri} permanent
}
